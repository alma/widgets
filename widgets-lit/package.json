{
  "name": "@alma/widgets-lit",
  "version": "1.0.0",
  "description": "Optimized Alma Widgets using Lit web components - Lightweight and performant",
  "type": "module",
  "main": "dist/alma-widgets.js",
  "module": "dist/alma-widgets.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "npm run build && concurrently -n \"BUILD,SERVE\" -c \"cyan,green\" \"npm run build:watch\" \"npm run serve\"",
    "dev:watch": "npm run build:watch",
    "dev:serve": "WATCH_MODE=true node examples/serve.js",
    "build": "tsc && vite build",
    "build:watch": "vite build --watch",
    "serve": "WATCH_MODE=true node examples/serve.js",
    "test": "web-test-runner",
    "test:watch": "web-test-runner --watch",
    "test:coverage": "web-test-runner --coverage"
  },
  "keywords": [
    "alma",
    "widgets",
    "web-components",
    "lit",
    "payment"
  ],
  "author": "Alma",
  "license": "MIT",
  "dependencies": {
    "lit": "^3.1.0"
  },
  "devDependencies": {
    "@esm-bundle/chai": "^4.3.4-fix.0",
    "@open-wc/testing": "^4.0.0",
    "@types/mocha": "^10.0.10",
    "@web/dev-server-esbuild": "^1.0.5",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-playwright": "^0.11.1",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.11",
    "sinon": "^21.0.1",
    "terser": "^5.46.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vite-plugin-dts": "^3.7.0"
  }
}
